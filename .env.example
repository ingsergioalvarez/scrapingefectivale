# --- App ---
APP_PORT=4000
APP_BASE_URL=http://localhost:4000

# --- MySQL (Telegram: cortes saldo 5:00/17:00, solicitudes gasolina, aclaraciones) ---
# Crea la base en MySQL y apunta aquí. Las tablas extra se crean al arrancar el servidor (ensureTelegramMysqlTables).
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ConrolVehicular

# --- Admin web (/admin/gasolina, API /api/admin/*) ---
# Efectivale no ofrece API pública para dispersar saldo: el admin aprueba en esta app y el servidor
# ejecuta Playwright (mismo flujo que un humano en el portal). ADMIN_API_KEY protege esa pantalla y la API.
ADMIN_API_KEY=

# --- Telegram (BotFather) ---
# 1) En Telegram: @BotFather → /newbot → copia el token en TELEGRAM_BOT_TOKEN.
# 2) Cualquier usuario puede escribir al bot; las solicitudes de gasolina quedan en MySQL y un admin las aprueba
#    en la web: http://localhost:5173/admin/gasolina (clave = ADMIN_API_KEY).
# 3) No necesitas TELEGRAM_ADMIN_CHAT_IDS para ese flujo (no se usa en el código actual).
TELEGRAM_BOT_TOKEN=
# Si ves error 409 Conflict (polling): solo un proceso puede usar el mismo token. Cierra el otro servidor o:
# TELEGRAM_DISABLE_BOT=true  en la segunda instancia (solo API, sin bot).
TELEGRAM_DISABLE_BOT=false

# --- Cifrado de contraseñas en Excel ---
ENCRYPTION_KEY_BASE64=

# --- Playwright (Efectivale) ---
PLAYWRIGHT_HEADLESS=true
EFECTIVALE_DEBUG_HEADFUL=false
EFECTIVALE_SLOWMO_MS=0

# --- Correo (reporte Excel Efectivale 13:00, opcional) ---
REPORT_SMTP_HOST=smtp.uservers.net
REPORT_SMTP_PORT=587
REPORT_SMTP_SECURE=false
REPORT_SMTP_USER=
REPORT_SMTP_PASS=
REPORT_SMTP_FROM=
REPORT_SMTP_TO=
